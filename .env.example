# Polymarket Trading Credentials
# IMPORTANT: Never share these credentials!

# Your MetaMask wallet private key (starts with 0x)
# Export from MetaMask: Account Details > Export Private Key
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Your public wallet address (starts with 0x)
# This is the address you see in MetaMask
POLYMARKET_FUNDER_ADDRESS=0x_your_wallet_address_here

# Builder API Keys (only for SignatureType 1 or 2)
# Create them at: https://polymarket.com/settings/builder-codes
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here
