# Polymarket Trading Credentials
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit the .env file!

# Your MetaMask wallet private key (starts with 0x)
# Export from MetaMask: Account Details > Export Private Key
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Your public wallet address (starts with 0x)
POLYMARKET_FUNDER_ADDRESS=0x_your_wallet_address_here

# Polymarket Builder API keys (optional - auto-derived from private key if omitted)
# Get from: https://polymarket.com/settings/builder-codes
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_PASSPHRASE=your_passphrase
